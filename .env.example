# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TG_ID=your_telegram_id
DB_PATH=lfl_bot.db
# Privacy retention: logged user messages older than this are purged on startup.
MSG_RETENTION_DAYS=30

# ── Mini App API (api.py) ─────────────────────────────────────────────────────
# Comma-separated allowed CORS origins (default: https://lflagent.ru)
CORS_ORIGINS=https://lflagent.ru

# ── Admin panel (admin/app.py) ────────────────────────────────────────────────
# REQUIRED in production. Without these, admin login is disabled / sessions reset.
# Generate a key:  python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=
# Preferred: a werkzeug password hash. Generate:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('YOURPASS'))"
ADMIN_PASSWORD_HASH=
# Fallback: plaintext password (compared in constant time). Use only if no hash.
ADMIN_PASSWORD=
# Set to 1/true only when the panel is served over HTTPS (enables Secure cookie).
ADMIN_HTTPS=
# Bind address for the Flask panel (default 127.0.0.1 — keep it local).
ADMIN_HOST=127.0.0.1

# ── Scraper proxies (optional) ────────────────────────────────────────────────
PROXY_URL=
SCRAPERAPI_KEY=
# Cloudflare Worker proxy: both URL and secret must be set to use it.
CF_WORKER_URL=
CF_WORKER_SECRET=

# ── Optional: Groq text shortening ────────────────────────────────────────────
# Comment summarization is OPT-IN (it sends user text to a 3rd party). Without
# GROQ_SUMMARIZE_COMMENTS=1 long comments are truncated locally instead.
GROQ_API_KEY=
GROQ_SUMMARIZE_COMMENTS=
